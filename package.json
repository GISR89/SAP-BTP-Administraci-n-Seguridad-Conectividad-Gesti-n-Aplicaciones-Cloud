{
  "name": "projectcap2",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "rimraf": "^6.1.3"
  },
  "scripts": {
    "start": "cds-serve",
    "build": "rimraf resources mta_archives && mbt build --mtar projectcap2_1.0.0.mtar",
    "deploy": "cf deploy mta_archives/projectcap2_1.0.0.mtar --retries 1",
    "undeploy": "cf undeploy project_fiori2 --delete-services --delete-service-keys --delete-service-brokers",
    "build-deploy": "npm run build && npm run deploy"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": "xsuaa",
      "db": "hana"
    }
  }
}
